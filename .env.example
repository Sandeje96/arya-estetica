# ──────────────────────────────────────────────────────────────────────────────
# Variables de entorno — Arya Estética
# Copiar este archivo como .env y completar los valores reales.
# En Railway, cargar estas variables en la sección "Variables" del servicio.
# ──────────────────────────────────────────────────────────────────────────────

# ── Base de datos ─────────────────────────────────────────────────────────────
# Railway la inyecta automáticamente al conectar el plugin PostgreSQL.
# En local: reemplazar con la URL de tu DB local.
DATABASE_URL="postgresql://usuario:password@host:5432/arya_estetica"

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
# AUTH_SECRET: generar con: openssl rand -base64 32
AUTH_SECRET="REEMPLAZAR_CON_SECRETO_SEGURO_32_CHARS"
# AUTH_URL: URL pública del deploy (Railway la muestra en el dashboard)
AUTH_URL="https://TU-APP.up.railway.app"

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_USERNAME="arya"
ADMIN_PASSWORD="REEMPLAZAR_CON_PASSWORD_SEGURO"

# ── Negocio ───────────────────────────────────────────────────────────────────
# Número de WhatsApp sin + ni espacios (para links wa.me)
BUSINESS_WHATSAPP="5493764285491"

# URL pública usada para generar el QR de las gift cards
PUBLIC_URL="https://TU-APP.up.railway.app"

# ── Cron ─────────────────────────────────────────────────────────────────────
# Secret para proteger el endpoint POST /api/reminders/cron
# Generar con: openssl rand -hex 32
CRON_SECRET="REEMPLAZAR_CON_SECRETO_SEGURO_HEX"
